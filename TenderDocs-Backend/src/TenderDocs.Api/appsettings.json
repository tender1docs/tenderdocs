{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "TenderDocs",
    "Audience": "TenderDocsClient",
    "Secret": "",
    "AccessTokenMinutes": 60
  },
  "Encryption": {
    "Key": ""
  },
  "Storage": {
    "Local": {
      "RootPath": "/app/storage"
    }
  },
  "Compression": {
    "Enabled": true,
    "Level": "Balanced",
    "Ghostscript": {
      "Enabled": true,
      "ExecutablePath": "",
      "TimeoutSeconds": 120
    }
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "",
    "DriveFolderId": ""
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "From": ""
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost:3000"]
  },
  "Swagger": {
    "Enabled": true
  },
  "AllowedHosts": "*"
}
