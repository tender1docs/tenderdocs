# ─────────────────────────────────────────────────────────────
# TenderDocs — environment configuration
# Copy to ".env" (docker compose reads it automatically) and fill in.
# ─────────────────────────────────────────────────────────────

# --- Gateway / runtime ---
ASPNETCORE_ENVIRONMENT=Production
GATEWAY_PORT=8080
SWAGGER_ENABLED=false
SEED_ENABLED=true

# --- PostgreSQL (REQUIRED) ---
POSTGRES_DB=tenderdocs
POSTGRES_USER=tenderdocs
POSTGRES_PASSWORD=change-me-strong-db-password
# The API builds its connection string from the POSTGRES_* values above.
# If you connect to an external DB instead, set this directly in docker-compose.

# --- JWT (REQUIRED) ---
# Must be at least 32 characters.
JWT_SECRET=change-me-to-a-long-random-32+char-secret
JWT_ISSUER=TenderDocs
JWT_AUDIENCE=TenderDocsClient

# --- Encryption key for stored storage credentials (REQUIRED) ---
ENCRYPTION_KEY=change-me-encryption-key

# --- Google Drive / Google OAuth login (OPTIONAL until you connect Drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DRIVE_FOLDER_ID=

# --- SMTP (OPTIONAL — email notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- Frontend (existing app) ---
# Path to the existing frontend folder that contains its own Dockerfile.
FRONTEND_CONTEXT=../TenderDocs-Frontend/frontend
VITE_API_BASE_URL=/api
