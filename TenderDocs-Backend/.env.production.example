# ===========================================================================
# TenderDocs — PRODUCTION environment template.
# Copy to `.env` next to docker-compose.prod.yml and fill in REAL values.
# NEVER commit the filled-in .env. Rotate any secret that has ever been shared.
# ===========================================================================

# ---- Public address ----
DOMAIN=tenderdocs.example.com
PUBLIC_URL=https://tenderdocs.example.com

# ---- GHCR image repo (owner/name, lowercase) used by docker-compose.prod.yml ----
GHCR_REPO=tender1docs/tenderdocs

# ---- PostgreSQL (use a long random password) ----
POSTGRES_DB=tenderdocs
POSTGRES_USER=tenderdocs
POSTGRES_PASSWORD=__CHANGE_ME__            # e.g. openssl rand -base64 24

# ---- JWT (REQUIRED, 32+ random bytes) ----
JWT_SECRET=__CHANGE_ME__                   # e.g. openssl rand -base64 48
JWT_ISSUER=TenderDocs
JWT_AUDIENCE=TenderDocsClient

# ---- Encryption key for stored storage credentials (REQUIRED, 32 bytes base64) ----
ENCRYPTION_KEY=__CHANGE_ME__               # e.g. openssl rand -base64 32

# ---- Swagger / seeding in production ----
SWAGGER_ENABLED=false                      # turn off public API docs in prod
SEED_ENABLED=true                          # seeds demo data on first run; set false after review

# ---- Google Drive / Google login (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tenderdocs.example.com/api/google-drive/callback
GOOGLE_DRIVE_FOLDER_ID=
