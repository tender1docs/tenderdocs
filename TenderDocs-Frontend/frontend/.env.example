# Base URL the SPA uses to reach the backend API.
# In Docker (via nginx gateway) and local dev (Vite proxy) this is same-origin "/api".
# To call a remote API directly, set an absolute URL, e.g. http://localhost:8080/api
VITE_API_BASE_URL=/api

# Default credentials prefilled on the login screen (match the seeded admin).
VITE_DEMO_EMAIL=admin@tenderdocs.io
VITE_DEMO_PASSWORD=Admin@12345

# "Sign in with Google" client id. Must equal the backend GOOGLE_CLIENT_ID and the
# OAuth client must list http://localhost:8080 under Authorized JavaScript origins.
# Leave empty to hide the Google button.
VITE_GOOGLE_CLIENT_ID=

# Optional: override the dev proxy target for `npm run dev`.
# VITE_PROXY_TARGET=http://localhost:8080
