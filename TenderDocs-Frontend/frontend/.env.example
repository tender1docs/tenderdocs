# Base URL the SPA uses to reach the backend API.
# In Docker (via nginx gateway) and local dev (Vite proxy) this is same-origin "/api".
# To call a remote API directly, set an absolute URL, e.g. http://localhost:8080/api
VITE_API_BASE_URL=/api

# "Sign in with Google" client id (the ONLY way to sign in). Must equal the backend
# GOOGLE_CLIENT_ID. The OAuth client must list your origin under "Authorized JavaScript origins"
# (http://localhost:8080 for local Docker, https://<your domain> in production).
# Leave empty to hide the Google button. In production this is baked in at image-build time.
VITE_GOOGLE_CLIENT_ID=

# Optional: override the dev proxy target for `npm run dev`.
# VITE_PROXY_TARGET=http://localhost:8080
