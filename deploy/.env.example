# ===========================================================================
# TenderDocs — production env TEMPLATE for docker-compose.server.yml
#
# This *.example file is COMMITTED to Git, so it must contain PLACEHOLDERS ONLY.
# Copy it to ".env" in this folder and fill in REAL values there.
# The real ".env" is gitignored and must NEVER be committed or pushed.
# Generate strong secrets with:  openssl rand -hex 32
# ===========================================================================

# ---- Your domain (no https:// for DOMAIN; with https:// for PUBLIC_URL) ----
DOMAIN=tenderdocs.yourdomain.com
PUBLIC_URL=https://tenderdocs.yourdomain.com

# ---- PostgreSQL ----
POSTGRES_DB=tenderdocs
POSTGRES_USER=tenderdocs
POSTGRES_PASSWORD=CHANGE_ME_long_random        # openssl rand -hex 24

# ---- JWT signing (REQUIRED) ----
JWT_SECRET=CHANGE_ME_long_random               # openssl rand -hex 48
JWT_ISSUER=TenderDocs
JWT_AUDIENCE=TenderDocsClient

# ---- Encryption key for stored storage credentials (REQUIRED) ----
ENCRYPTION_KEY=CHANGE_ME_long_random           # openssl rand -hex 32

# ---- Production toggles ----
SWAGGER_ENABLED=false                          # keep API docs private in prod
SEED_ENABLED=false                             # true = create demo data on first run

# ---- Google login / Drive (REQUIRED for sign-in; Drive optional) ----
# Create your OWN OAuth client in Google Cloud Console — do NOT reuse anyone else's id.
# Use the SAME client id in TenderDocs-Frontend/frontend/.env (VITE_GOOGLE_CLIENT_ID),
# and in the OAuth client add https://<your domain> to "Authorized JavaScript origins"
# and the redirect URI below to "Authorized redirect URIs". See PRE-DEPLOYMENT-CHECKLIST.md §3.
GOOGLE_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://tenderdocs.yourdomain.com/api/google-drive/callback
GOOGLE_DRIVE_FOLDER_ID=YOUR_DRIVE_FOLDER_ID
